# Cluster-domain-dependent URLs for LiteMaaS (single source of truth).
# All traffic through gateway host litemaas.apps.rosa.rosa-qfqg2.ybzo.p3.openshiftapps.com
# Update domain from repo root: ./update-cluster-domain.sh apps.your-cluster.example.com
CORS_ORIGIN=https://litemaas.apps.rosa.rosa-qfqg2.ybzo.p3.openshiftapps.com
OAUTH_ISSUER=https://oauth-openshift.apps.rosa.rosa-qfqg2.ybzo.p3.openshiftapps.com
OAUTH_CALLBACK_URL=https://litemaas.apps.rosa.rosa-qfqg2.ybzo.p3.openshiftapps.com/api/auth/callback
LITELLM_API_URL=https://litemaas.apps.rosa.rosa-qfqg2.ybzo.p3.openshiftapps.com/v1
FRONTEND_HOST=litemaas.apps.rosa.rosa-qfqg2.ybzo.p3.openshiftapps.com
